# Copy this file to `.env.local` and replace placeholders with values from Supabase.
# Used by Python jobs (`jobs/config.py`) — keep in project root.

# Supabase → Settings → API → Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase → Settings → API → anon public key
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase → Settings → Database → Connection string (direct or pooler)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.dsulbrlmqjhrfgasjwtl.supabase.co:5432/postgres
